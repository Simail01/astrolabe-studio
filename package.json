{
  "name": "astrolabe-studio",
  "version": "0.1.0",
  "private": true,
  "main": "packages/core/dist/main/index.js",
  "scripts": {
    "dev": "turbo dev --filter=@astrolabe/core",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "start": "pnpm --filter @astrolabe/core start",
    "package:win": "pnpm build && electron-builder --win --config electron-builder.yml"
  },
  "devDependencies": {
    "electron-builder": "^25.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "pnpm@9.0.0"
}
